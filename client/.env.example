# LifeSnaps environment variables
# Copy this file to .env.local and fill in your values.

# Supabase (required)
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mapbox Search (optional — enables city autocomplete in Travel & Activities forms)
# Get a free token at https://account.mapbox.com/ (50,000 geocoding requests/month free)
# Leave blank to use plain text city input instead.
REACT_APP_MAPBOX_TOKEN=
