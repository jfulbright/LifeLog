# Copy this file to .env and fill in your values.
# Never commit the real .env — it is gitignored.

SETLISTFM_API_KEY=your_setlist_fm_api_key_here

# Allowed CORS origin for the proxy server.
# Local dev: http://localhost:3000
# Production: https://lifesnaps.org
CORS_ORIGIN=http://localhost:3000

# Google Cloud Vision API key for wine label OCR (POST /api/wine/scan)
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable "Cloud Vision API" in your project, then create an API key.
# Free tier: 1,000 units/month. At personal scale you will never exceed this.
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_key_here
